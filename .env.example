# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID
# The bot will only respond to this user
ALLOWED_USER_ID=your_telegram_user_id_here

# Channel Selection: "telegram", "whatsapp", or "dual"
ACTIVE_CHANNEL=telegram
ACTIVE_MODEL=your_provider_and_model_id_here

# Local/hosted server base URL used in operator links
PORT=your_port_here
PUBLIC_BASE_URL=http://localhost:your_port_here
OPERATOR_TOKEN=replace_with_a_long_random_operator_token
WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret

# WhatsApp: your own WhatsApp JID
WHATSAPP_ALLOWED_JID=your_whatsapp_jid_here

# Model provider credentials
ALIBABA_API_KEY=sk-your_alibaba_model_studio_api_key_here
ALIBABA_BASE_URL=your_compatible_api_base_url_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Speech
GROQ_API_KEY=your_groq_api_key_here
RESURGE_API_KEY=your_resurge_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
NEON_DATABASE_URL=your_neon_database_url_here
GOOGLE_TTS_PROJECT_ID=your_google_cloud_project_id
GOOGLE_TTS_CREDENTIALS_B64=your_base64_encoded_service_account_json
GOOGLE_TTS_VOICE_NAME=your_tts_voice_name_here
GOOGLE_TTS_LANGUAGE_CODE=your_tts_language_code_here
GOOGLE_TTS_MONTHLY_CHAR_LIMIT=your_monthly_char_limit_here
GOOGLE_TTS_MAX_BYTES_PER_REQUEST=your_max_bytes_per_request_here

# Proactive System Settings
PROACTIVE_MORNING_BRIEFING_TIME=your_morning_briefing_time_here
PROACTIVE_EVENING_RECAP_TIME=your_evening_recap_time_here
PROACTIVE_HEARTBEAT_INTERVAL_HOURS=your_heartbeat_interval_here
PROACTIVE_TIMEZONE=your_timezone_here

# Optional remote MCP config
MCP_CONFIG_JSON_B64=
